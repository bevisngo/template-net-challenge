# ── App ───────────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=production

# ── Database (MySQL) ──────────────────────────────────────────────────────────
# Docker service name used as hostname inside the container network
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=chatuser
DB_PASSWORD=chatpassword
DB_DATABASE=templatenet_chat

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# ── AI — REQUIRED ─────────────────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── MinIO (object storage) ────────────────────────────────────────────────────
# MINIO_ENDPOINT      = Docker-internal hostname (backend → MinIO)
# MINIO_PUBLIC_ENDPOINT = Host reachable from the browser (for presigned URLs)
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_PUBLIC_ENDPOINT=localhost
MINIO_PUBLIC_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=templatenet-files
MINIO_USE_SSL=false

# ── Qdrant (vector DB) ────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ── Upload ────────────────────────────────────────────────────────────────────
MAX_FILE_SIZE=52428800
